{
    "buildCommand": "npm run build",
    "outputDirectory": "build",
    "framework": null,
    "env": {
        "VITE_API_BASE_URL": "/api"
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index"
        },
        {
            "source": "/((?!assets/|dicts/|sounds/|manifest\\.json|robots\\.txt|926\\.json|404\\.html|favicon\\.ico).*)",
            "destination": "/index.html"
        }
    ]
}